# App
DEBUG=false
APP_BASE_URL=https://your-service-hash-region.a.run.app
TIMEZONE=Asia/Taipei

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# LINE LIFF
LIFF_ID=your_liff_id
LIFF_CHANNEL_ID=your_liff_channel_id      # LINE Login channel ID linked to LIFF
LIFF_CHANNEL_SECRET=your_liff_channel_secret  # LINE Login channel secret (for Dashboard OAuth)

# Database (Cloud SQL — use Unix socket for Cloud Run)
# Local dev:    postgresql://user:pass@localhost:5432/dbname
# Cloud Run:    postgresql+psycopg2://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Email (Mailgun)
MAILGUN_API_KEY=key-xxxxxxxxxxxx
MAILGUN_FROM_EMAIL=noreply@your-verified-domain.com

# Session
SESSION_SECRET_KEY=generate_with_openssl_rand_hex_32
